; pg_epanet test fixture — minimal synthetic network
; 3 junctions, 1 reservoir, 1 tank, 1 pump, 1 valve, 4 pipes
; All values are illustrative, not based on any real network.

[TITLE]
pg_epanet simple test network

[JUNCTIONS]
;ID              Elev     Demand   Pattern
 J1              100.0    10.0     PD1
 J2              95.0     5.0      PD1
 J3              90.0     0.0

[RESERVOIRS]
;ID              Head     Pattern
 R1              150.0

[TANKS]
;ID     Elev  InitLvl  MinLvl  MaxLvl  Diam  MinVol  VolCurve
 T1     80.0   5.0      1.0    10.0    10.0   0.0

[PIPES]
;ID     Node1  Node2   Length  Diameter  Roughness  MinorLoss  Status
